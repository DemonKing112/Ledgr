# Copy this file to .env and fill in your values
# NEVER commit the real .env file

# Server port
PORT=3001

# JWT secret — use a long random string (run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=replace-me-with-a-random-64-char-string
JWT_REFRESH_SECRET=replace-me-with-another-random-64-char-string

# Frontend URL for CORS (no trailing slash)
FRONTEND_URL=http://localhost:5500

# PostgreSQL connection string (Neon, Render, or local)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Stripe (subscription payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_BIZ_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
